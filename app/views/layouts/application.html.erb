<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Projeto Final" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Projeto Final">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="stylesheet" href="/leaflet/leaflet.css" />
    <script src="/leaflet/leaflet.js"></script>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex flex-col min-h-screen bg-gray-50">
    <!-- Navbar -->
    <nav class="fixed top-0 left-0 right-0 bg-white border-b border-gray-200 shadow-sm z-50">
      <div class="container mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-8">
            <!-- Site title removed: Home link is available in the navbar -->
            <%= link_to root_path, class: "hidden md:inline text-gray-600 hover:text-gray-800 transition" do %>
              <span class="text-sm font-medium">Home</span>
            <% end %>

            <% if authenticated? %>
              <div class="hidden md:flex items-center gap-6">
                <%= link_to profile_path, class: "text-gray-600 hover:text-gray-800 transition" do %>
                  <span class="text-sm font-medium">Perfil</span>
                <% end %>

                <%= link_to private_conversations_path, class: "text-gray-600 hover:text-gray-800 transition" do %>
                  <span class="text-sm font-medium">Chat</span>
                <% end %>

                <%= link_to map_path, class: "text-gray-600 hover:text-gray-800 transition", data: { turbo: false } do %>
                  <span class="text-sm font-medium">🗺️ Mapa</span>
                <% end %>
              </div>
            <% else %>
              <%= link_to map_path, class: "hidden md:inline text-gray-600 hover:text-gray-800 transition", data: { turbo: false } do %>
                <span class="text-sm font-medium">🗺️ Mapa</span>
              <% end %>
            <% end %>
          </div>

          <div class="flex items-center gap-4">
            <% if authenticated? %>
              <span class="text-sm text-gray-600 hidden md:inline">Olá, <%= Current.user.name %></span>
              <%= button_to "Logout", session_path, method: :delete, class: "rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 active:bg-red-700" %>
            <% else %>
              <%= link_to "Login", new_session_path, class: "px-4 py-2 rounded-md bg-blue-600 text-white hover:bg-blue-500 text-sm font-semibold" %>
              <%= link_to "Sign up", new_user_path, class: "px-4 py-2 rounded-md border border-blue-600 text-blue-600 hover:bg-blue-50 text-sm font-semibold" %>
            <% end %>
          </div>
        </div>

        <!-- Mobile Navigation -->
        <div class="flex md:hidden justify-around mt-4 pt-4 border-t border-gray-200">
          <%= link_to root_path, class: "flex flex-col items-center gap-1 text-gray-600 hover:text-gray-800 transition" do %>
            <span class="text-sm font-medium">Home</span>
            <span class="text-xs">Home</span>
          <% end %>

          <% if authenticated? %>
            <%= link_to profile_path, class: "flex flex-col items-center gap-1 text-gray-600 hover:text-gray-800 transition" do %>
              <span class="text-sm font-medium">Perfil</span>
              <span class="text-xs">Perfil</span>
            <% end %>

            <%= link_to private_conversations_path, class: "flex flex-col items-center gap-1 text-gray-600 hover:text-gray-800 transition" do %>
              <span class="text-sm font-medium">Chat</span>
              <span class="text-xs">Chat</span>
            <% end %>
          <% end %>

          <%= link_to map_path, class: "flex flex-col items-center gap-1 text-gray-600 hover:text-gray-800 transition", data: { turbo: false } do %>
            <span class="text-sm font-medium">🗺️</span>
            <span class="text-xs">Mapa</span>
          <% end %>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1 container mx-auto mt-32 px-5 py-8">
      <% if flash[:notice] %>
        <div class="mb-4 rounded-lg bg-green-100 border border-green-300 px-4 py-3 text-green-800 text-sm font-medium">
          <%= flash[:notice] %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="mb-4 rounded-lg bg-red-100 border border-red-300 px-4 py-3 text-red-800 text-sm font-medium">
          <%= flash[:alert] %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white text-center py-6 mt-16">
      <p>&copy; 2026 ProjetoFinal. Todos os direitos reservados.</p>
    </footer>

    <!-- Chatbot Widget -->
    <div id="chatbot-widget" class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">

      <!-- Chat Window -->
      <div id="chatbot-window" class="hidden w-80 sm:w-96 bg-white rounded-2xl shadow-2xl border border-gray-200 flex flex-col overflow-hidden" style="height: 480px;">
        <!-- Header -->
        <div class="bg-green-600 px-4 py-3 flex items-center justify-between">
          <div class="flex items-center gap-2">
            <span class="text-xl">🤖</span>
            <div>
              <p class="text-white font-semibold text-sm">Assistente ECO</p>
              <p class="text-green-100 text-xs">Powered by IA</p>
            </div>
          </div>
          <button onclick="toggleChatbot()" class="text-white hover:text-green-200 text-xl leading-none">&times;</button>
        </div>

        <!-- Messages -->
        <div id="chatbot-messages" class="flex-1 overflow-y-auto p-4 space-y-3 bg-gray-50">
          <div class="flex justify-start">
            <div class="bg-white border border-gray-200 rounded-2xl rounded-tl-sm px-4 py-2 text-sm text-gray-700 max-w-xs shadow-sm">
              Olá! 👋 Sou o assistente do ECO. Posso ajudar com dúvidas sobre a plataforma, itens disponíveis e como funciona o processo de doação. Como posso ajudar?
            </div>
          </div>
        </div>

        <!-- Input -->
        <div class="border-t border-gray-200 p-3 bg-white">
          <div class="flex gap-2">
            <input id="chatbot-input" type="text" placeholder="Digite sua pergunta..."
              class="flex-1 rounded-full border border-gray-300 px-4 py-2 text-sm outline-none focus:border-green-500 focus:ring-1 focus:ring-green-500"
              onkeydown="if(event.key==='Enter') sendChatMessage()" />
            <button onclick="sendChatMessage()"
              class="rounded-full bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-500 active:bg-green-700">
              ➤
            </button>
          </div>
        </div>
      </div>

      <!-- Toggle Button -->
      <button onclick="toggleChatbot()"
        class="w-14 h-14 rounded-full bg-green-600 text-white shadow-lg hover:bg-green-500 active:bg-green-700 flex items-center justify-center text-2xl transition-transform hover:scale-110"
        title="Assistente ECO">
        🤖
      </button>
    </div>

    <script>
      function toggleChatbot() {
        var win = document.getElementById('chatbot-window');
        win.classList.toggle('hidden');
        if (!win.classList.contains('hidden')) {
          document.getElementById('chatbot-input').focus();
        }
      }

      function sendChatMessage() {
        var input = document.getElementById('chatbot-input');
        var question = input.value.trim();
        if (!question) return;

        appendMessage(question, 'user');
        input.value = '';
        appendTyping();

        fetch('<%= chatbot_ask_path %>', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]') ? document.querySelector('meta[name="csrf-token"]').content : ''
          },
          body: JSON.stringify({ question: question })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          removeTyping();
          appendMessage(data.answer || data.error, 'bot');
        })
        .catch(function() {
          removeTyping();
          appendMessage('Erro ao conectar. Tente novamente.', 'bot');
        });
      }

      function appendMessage(text, role) {
        var container = document.getElementById('chatbot-messages');
        var div = document.createElement('div');
        div.className = 'flex ' + (role === 'user' ? 'justify-end' : 'justify-start');
        var bubble = document.createElement('div');
        bubble.className = role === 'user'
          ? 'bg-green-600 text-white rounded-2xl rounded-tr-sm px-4 py-2 text-sm max-w-xs shadow-sm'
          : 'bg-white border border-gray-200 rounded-2xl rounded-tl-sm px-4 py-2 text-sm text-gray-700 max-w-xs shadow-sm';
        bubble.style.whiteSpace = 'pre-wrap';
        bubble.textContent = text;
        div.appendChild(bubble);
        container.appendChild(div);
        container.scrollTop = container.scrollHeight;
      }

      function appendTyping() {
        var container = document.getElementById('chatbot-messages');
        var div = document.createElement('div');
        div.id = 'chatbot-typing';
        div.className = 'flex justify-start';
        div.innerHTML = '<div class="bg-white border border-gray-200 rounded-2xl rounded-tl-sm px-4 py-2 text-sm text-gray-400 shadow-sm">digitando...</div>';
        container.appendChild(div);
        container.scrollTop = container.scrollHeight;
      }

      function removeTyping() {
        var el = document.getElementById('chatbot-typing');
        if (el) el.remove();
      }
    </script>
  </body>
</html>
