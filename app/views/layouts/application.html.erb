<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Projeto Final" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Projeto Final">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex flex-col min-h-screen bg-gray-50">
    <!-- Navbar -->
    <nav class="fixed top-0 left-0 right-0 bg-white border-b border-gray-200 shadow-sm z-50">
      <div class="container mx-auto px-4 py-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-8">
            <%= link_to "ProjetoFinal", root_path, class: "text-2xl font-bold text-gray-800 hover:text-gray-600" %>
            
            <% if authenticated? %>
              <div class="hidden md:flex items-center gap-6">
                <%= link_to root_path, class: "text-gray-600 hover:text-gray-800 transition" do %>
                  <span class="text-2xl">🏠</span>
                <% end %>
                
                <%= link_to dashboard_path, class: "text-gray-600 hover:text-gray-800 transition" do %>
                  <span class="text-2xl">📊</span>
                <% end %>
                
                <%= link_to profile_path, class: "text-gray-600 hover:text-gray-800 transition" do %>
                  <span class="text-2xl">👤</span>
                <% end %>
                
                <%= link_to chats_path, class: "text-gray-600 hover:text-gray-800 transition" do %>
                  <span class="text-2xl">💬</span>
                <% end %>
              </div>
            <% end %>
          </div>

          <div class="flex items-center gap-4">
            <% if authenticated? %>
              <span class="text-sm text-gray-600 hidden md:inline">Olá, <%= Current.user.name %></span>
              <%= button_to "Logout", session_path, method: :delete, class: "rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 active:bg-red-700" %>
            <% else %>
              <%= link_to "Login", new_session_path, class: "px-4 py-2 rounded-md bg-blue-600 text-white hover:bg-blue-500 text-sm font-semibold" %>
              <%= link_to "Sign up", new_user_path, class: "px-4 py-2 rounded-md border border-blue-600 text-blue-600 hover:bg-blue-50 text-sm font-semibold" %>
            <% end %>
          </div>
        </div>

        <!-- Mobile Navigation -->
        <% if authenticated? %>
          <div class="flex md:hidden justify-around mt-4 pt-4 border-t border-gray-200">
            <%= link_to root_path, class: "flex flex-col items-center gap-1 text-gray-600 hover:text-gray-800 transition" do %>
              <span class="text-2xl">🏠</span>
              <span class="text-xs">Home</span>
            <% end %>
            
            <%= link_to dashboard_path, class: "flex flex-col items-center gap-1 text-gray-600 hover:text-gray-800 transition" do %>
              <span class="text-2xl">📊</span>
              <span class="text-xs">Dashboard</span>
            <% end %>
            
            <%= link_to profile_path, class: "flex flex-col items-center gap-1 text-gray-600 hover:text-gray-800 transition" do %>
              <span class="text-2xl">👤</span>
              <span class="text-xs">Perfil</span>
            <% end %>
            
            <%= link_to chats_path, class: "flex flex-col items-center gap-1 text-gray-600 hover:text-gray-800 transition" do %>
              <span class="text-2xl">💬</span>
              <span class="text-xs">Chat</span>
            <% end %>
          </div>
        <% end %>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1 container mx-auto mt-32 px-5 py-8">
      <%= yield %>
    </main>

    <!-- Footer -->
    <footer class="bg-gray-800 text-white text-center py-6 mt-16">
      <p>&copy; 2026 ProjetoFinal. Todos os direitos reservados.</p>
    </footer>
  </body>
</html>
