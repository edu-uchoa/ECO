<div class="space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-3xl font-bold">Chat Comunitário</h1>
  </div>

  <div class="rounded-lg border border-gray-200 bg-white shadow-sm">
    <div class="flex flex-col h-96">
      <!-- Messages Container -->
      <div class="flex-1 overflow-y-auto space-y-4 p-4 bg-gray-50">
        <% if @chat_messages.any? %>
          <% @chat_messages.each do |message| %>
            <div class="flex gap-3 <% if message.user == Current.user %>justify-end<% end %>">
              <div class="<% if message.user == Current.user %>order-2<% end %>">
                <p class="text-sm font-semibold text-gray-700">
                  <%= message.user.name %>
                </p>
                <div class="mt-1 rounded-lg <% if message.user == Current.user %>bg-blue-600 text-white<% else %>bg-white border border-gray-200<% end %> px-4 py-2 shadow-sm">
                  <p class="text-sm"><%= message.content %></p>
                </div>
                <p class="mt-1 text-xs <% if message.user == Current.user %>text-right<% end %> text-gray-500">
                  <%= l(message.created_at, format: :short) %>
                </p>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="flex items-center justify-center h-full">
            <p class="text-gray-400">Nenhuma mensagem ainda. Seja o primeiro a falar!</p>
          </div>
        <% end %>
      </div>

      <!-- Input Form -->
      <div class="border-t border-gray-200 bg-white p-4">
        <%= form_with model: @chat_message, url: chats_path, method: :post, local: true, class: "flex gap-2" do |form| %>
          <div class="flex-1">
            <%= form.text_area :content, placeholder: "Digite sua mensagem...", rows: 1, class: "block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500 resize-none" %>
          </div>
          <%= form.submit "Enviar", class: "rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white shadow-sm hover:bg-blue-500 active:bg-blue-700" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="flex gap-2">
    <%= link_to "Voltar", dashboard_path, class: "rounded-lg bg-gray-300 px-4 py-2 font-semibold text-gray-900 shadow-sm hover:bg-gray-400" %>
  </div>
</div>
