<div class="space-y-8">
  <div>
    <h1 class="text-3xl font-bold">🛡️ Moderação de Pontos de Coleta</h1>
    <p class="text-sm text-gray-500 mt-1">
      Área preparada para moderadores. Novos pins entram como <strong>pending</strong> e só aparecem no mapa público após aprovação.
    </p>
  </div>

  <section class="space-y-4">
    <h2 class="text-xl font-semibold">Pendentes (<%= @pending_points.size %>)</h2>

    <% if @pending_points.empty? %>
      <div class="rounded-lg border border-gray-200 bg-white p-4 text-sm text-gray-500">
        Nenhum ponto pendente no momento.
      </div>
    <% else %>
      <div class="space-y-4">
        <% @pending_points.each do |point| %>
          <article class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
              <div class="space-y-2">
                <h3 class="text-lg font-semibold"><%= point.title %></h3>
                <p class="text-sm text-gray-600"><strong>Endereço:</strong> <%= point.address %></p>
                <p class="text-sm text-gray-600"><strong>Coordenadas:</strong> <%= point.latitude %>, <%= point.longitude %></p>
                <% if point.opening_hours.present? %>
                  <p class="text-sm text-gray-600"><strong>Horário:</strong> <%= point.opening_hours %></p>
                <% end %>
                <% if point.description.present? %>
                  <p class="text-sm text-gray-700"><%= point.description %></p>
                <% end %>
                <p class="text-xs text-gray-500">Enviado por <%= point.user.name %> em <%= l(point.created_at, format: :short) %></p>
                <% if point.categories.present? %>
                  <div class="flex flex-wrap gap-2 pt-1">
                    <% point.categories.each do |category| %>
                      <span class="rounded-full bg-green-100 text-green-700 text-xs px-3 py-1"><%= category %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>

              <div class="flex flex-col gap-2 min-w-[220px]">
                <%= button_to "✅ Aprovar",
                      approve_moderation_collection_point_path(point),
                      method: :patch,
                      class: "w-full rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-500" %>

                <%= form_with url: reject_moderation_collection_point_path(point), method: :patch, class: "space-y-2" do |f| %>
                  <%= f.text_area :rejection_reason,
                        rows: 3,
                        placeholder: "Motivo da rejeição (obrigatório)",
                        class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
                  <%= f.submit "❌ Rejeitar",
                        class: "w-full rounded-lg bg-red-600 px-4 py-2 text-sm font-semibold text-white hover:bg-red-500" %>
                <% end %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    <% end %>
  </section>

  <section class="space-y-3">
    <h2 class="text-xl font-semibold">Moderados recentemente</h2>

    <div class="rounded-xl border border-gray-200 bg-white overflow-hidden">
      <table class="min-w-full text-sm">
        <thead class="bg-gray-50 text-gray-600">
          <tr>
            <th class="text-left px-4 py-3">Título</th>
            <th class="text-left px-4 py-3">Status</th>
            <th class="text-left px-4 py-3">Atualizado em</th>
            <th class="text-left px-4 py-3">Motivo rejeição</th>
          </tr>
        </thead>
        <tbody>
          <% @recently_moderated.each do |point| %>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3"><%= point.title %></td>
              <td class="px-4 py-3">
                <span class="rounded-full px-2 py-1 text-xs <%= point.approved? ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                  <%= point.status %>
                </span>
              </td>
              <td class="px-4 py-3"><%= l(point.updated_at, format: :short) %></td>
              <td class="px-4 py-3 text-gray-600"><%= point.rejection_reason.presence || '-' %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="space-y-3">
    <h2 class="text-xl font-semibold">🧾 Logs de moderação (auditoria)</h2>

    <div class="rounded-xl border border-gray-200 bg-white overflow-hidden">
      <table class="min-w-full text-sm">
        <thead class="bg-gray-50 text-gray-600">
          <tr>
            <th class="text-left px-4 py-3">Data/Hora</th>
            <th class="text-left px-4 py-3">Moderador</th>
            <th class="text-left px-4 py-3">Item</th>
            <th class="text-left px-4 py-3">Ação</th>
            <th class="text-left px-4 py-3">De → Para</th>
            <th class="text-left px-4 py-3">Motivo</th>
          </tr>
        </thead>
        <tbody>
          <% @moderation_logs.each do |log| %>
            <tr class="border-t border-gray-100">
              <td class="px-4 py-3"><%= l(log.created_at, format: :short) %></td>
              <td class="px-4 py-3"><%= log.moderator.name %></td>
              <td class="px-4 py-3"><%= log.collection_point.title %></td>
              <td class="px-4 py-3">
                <span class="rounded-full px-2 py-1 text-xs <%= log.approved? ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>">
                  <%= log.action_type %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-600"><%= [log.previous_status, log.new_status].join(" → ") %></td>
              <td class="px-4 py-3 text-gray-600"><%= log.reason.presence || '-' %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</div>
