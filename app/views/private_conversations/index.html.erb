<div class="mx-auto max-w-2xl space-y-6">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold">Minhas Conversas</h1>
    <%= link_to "Voltar", dashboard_path, class: "text-sm text-blue-600 hover:underline" %>
  </div>

  <% if @conversations.any? %>
    <div class="space-y-3">
      <% @conversations.each do |conversation| %>
        <% other = conversation.other_user(Current.user) %>
        <%= link_to private_conversation_path(conversation), class: "block rounded-lg border border-gray-200 p-4 hover:bg-gray-50 transition-colors" do %>
          <div class="flex items-center justify-between">
            <div>
              <p class="font-semibold text-gray-900"><%= other.name %></p>
              <% if conversation.messages.any? %>
                <p class="text-sm text-gray-500 mt-1 line-clamp-1"><%= conversation.messages.last.content %></p>
              <% else %>
                <p class="text-sm text-gray-400 mt-1 italic">Nenhuma mensagem ainda</p>
              <% end %>
            </div>
            <% if conversation.messages.any? %>
              <span class="text-xs text-gray-400"><%= time_ago_in_words(conversation.messages.last.created_at) %> atrás</span>
            <% end %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-lg border border-dashed border-gray-300 p-8 text-center">
      <p class="text-gray-500">Você ainda não tem conversas.</p>
      <p class="text-sm text-gray-400 mt-1">Visite o perfil de um usuário para iniciar um chat.</p>
    </div>
  <% end %>
</div>
