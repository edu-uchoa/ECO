
<div class="mx-auto md:w-2/3 w-full">
  <% if alert = flash[:alert] %>
    <p class="py-2 px-3 bg-red-50 mb-5 text-red-500 font-medium rounded-lg inline-block" id="alert"><%= alert %></p>
  <% end %>

  <% if notice = flash[:notice] %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Sign up</h1>

  <% if defined?(@user) && @user.respond_to?(:errors) && @user.errors.any? %>
    <div class="my-4 p-3 bg-red-50 border border-red-100 rounded">
      <p class="font-medium text-red-700">Please fix the following errors:</p>
      <ul class="list-disc list-inside mt-2 text-sm text-red-600">
        <% @user.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: (@user || User.new), local: true, class: "contents" do |form| %>
    <div class="my-5">
      <%= form.label :name, "Username", class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_field :name, required: true, autocomplete: "username", placeholder: "Choose a unique username", class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
      <% if (@user && @user.errors[:name].present?) %>
        <p class="text-red-500 text-sm mt-1"><%= @user.errors.full_messages_for(:name).join(', ') %></p>
      <% end %>
    </div>

    <div class="my-5">
      <%= form.label :email_address, "Email", class: "block text-sm font-medium text-gray-700" %>
  <%= form.email_field :email_address, required: true, autocomplete: "username", placeholder: "Enter your email address", class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full", inputmode: "email" %>
      <% if (@user && @user.errors[:email_address].present?) %>
        <p class="text-red-500 text-sm mt-1"><%= @user.errors.full_messages_for(:email_address).join(', ') %></p>
      <% end %>
    </div>

    <div class="my-5">
      <%= form.label :password, class: "block text-sm font-medium text-gray-700" %>
      <%= form.password_field :password, required: true, autocomplete: "new-password", placeholder: "Choose a password (min. 6 characters)", minlength: 6, maxlength: 72, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
      <% if (@user && @user.errors[:password].present?) %>
        <p class="text-red-500 text-sm mt-1"><%= @user.errors.full_messages_for(:password).join(', ') %></p>
      <% end %>
    </div>

    <div class="my-5">
      <%= form.label :password_confirmation, "Confirm password", class: "block text-sm font-medium text-gray-700" %>
      <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", placeholder: "Confirm your password", minlength: 6, maxlength: 72, class: "block shadow-sm rounded-md border border-gray-400 focus:outline-blue-600 px-3 py-2 mt-2 w-full" %>
      <% if (@user && @user.errors[:password_confirmation].present?) %>
        <p class="text-red-500 text-sm mt-1"><%= @user.errors.full_messages_for(:password_confirmation).join(', ') %></p>
      <% end %>
    </div>

    <div class="col-span-6 sm:flex sm:items-center sm:gap-4">
      <div class="inline">
        <%= form.submit "Create account", class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
      </div>

      <div class="mt-4 text-sm text-gray-500 sm:mt-0">
        <%= link_to "Already have an account? Sign in", new_session_path, class: "text-gray-700 underline hover:no-underline" %>
      </div>
    </div>
  <% end %>
</div>

