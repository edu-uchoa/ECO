<div class="space-y-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-3xl font-bold"><%= @user.name %></h1>
      <p class="text-gray-600 mt-2">Perfil de Usuário</p>
    </div>
    <% if authenticated? && Current.user != @user %>
      <%= button_to "Iniciar Chat", private_conversations_path(user_id: @user.id), method: :post,
        class: "rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-green-500 active:bg-green-700" %>
    <% end %>
  </div>

  <% if @available_posts.any? %>
    <div class="space-y-4">
      <h2 class="text-2xl font-bold flex items-center gap-2">
        ✅ Itens Disponíveis
        <span class="rounded-full bg-green-100 px-3 py-1 text-sm font-semibold text-green-700"><%= @available_posts.count %></span>
      </h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% @available_posts.each do |post| %>
          <div class="overflow-hidden rounded-lg border border-green-200 shadow-sm hover:shadow-md transition-shadow">
            <% if post.images.attached? %>
              <div class="h-48 overflow-hidden bg-gray-100">
                <%= image_tag post.images.first, alt: post.title, class: "h-full w-full object-cover" %>
              </div>
            <% else %>
              <div class="h-48 bg-gray-200 flex items-center justify-center">
                <span class="text-gray-400">Sem imagem</span>
              </div>
            <% end %>
            <div class="p-4 space-y-3">
              <h3 class="font-bold text-lg text-gray-900"><%= post.title %></h3>
              <p class="line-clamp-2 text-sm text-gray-700"><%= post.description %></p>
              <div class="flex flex-wrap gap-2">
                <span class="inline-block rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-700"><%= post.category %></span>
                <span class="inline-block rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700"><%= post.condition %></span>
              </div>
              <div class="text-sm text-gray-600">📍 <%= post.location %></div>
              <%= link_to "Ver Detalhes", post_path(post), class: "inline-block rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 w-full text-center" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="rounded-lg border-2 border-dashed border-green-200 p-8 text-center">
      <p class="text-gray-500">Nenhum item disponível no momento</p>
    </div>
  <% end %>

  <% if @taken_posts.any? %>
    <div class="space-y-4">
      <h2 class="text-2xl font-bold flex items-center gap-2">
        🔒 Itens Já Doados
        <span class="rounded-full bg-red-100 px-3 py-1 text-sm font-semibold text-red-700"><%= @taken_posts.count %></span>
      </h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% @taken_posts.each do |post| %>
          <div class="overflow-hidden rounded-lg border border-red-200 shadow-sm opacity-75">
            <% if post.images.attached? %>
              <div class="h-48 overflow-hidden bg-gray-100">
                <%= image_tag post.images.first, alt: post.title, class: ["h-full w-full object-cover grayscale"] %>
              </div>
            <% else %>
              <div class="h-48 bg-gray-200 flex items-center justify-center">
                <span class="text-gray-400">Sem imagem</span>
              </div>
            <% end %>
            <div class="p-4 space-y-3">
              <div class="flex items-center gap-2">
                <h3 class="font-bold text-lg text-gray-500"><%= post.title %></h3>
                <span class="rounded-full bg-red-100 px-2 py-0.5 text-xs font-semibold text-red-600">Doado</span>
              </div>
              <p class="line-clamp-2 text-sm text-gray-400"><%= post.description %></p>
              <div class="flex flex-wrap gap-2">
                <span class="inline-block rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-500"><%= post.category %></span>
                <span class="inline-block rounded-full bg-gray-100 px-3 py-1 text-xs font-medium text-gray-500"><%= post.condition %></span>
              </div>
              <div class="text-sm text-gray-400">📍 <%= post.location %></div>
              <%= link_to "Ver Detalhes", post_path(post), class: "inline-block rounded-lg bg-gray-400 px-4 py-2 text-sm font-semibold text-white shadow-sm w-full text-center" %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @available_posts.empty? && @taken_posts.empty? %>
    <div class="rounded-lg border-2 border-dashed border-gray-300 p-12 text-center">
      <p class="text-gray-600"><%= @user.name %> ainda não tem posts</p>
    </div>
  <% end %>


