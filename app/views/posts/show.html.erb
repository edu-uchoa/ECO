<div class="space-y-8">
  <% if @post.status == "taken" %>
    <div class="rounded-lg bg-red-50 border border-red-300 px-5 py-4 flex items-center gap-3">
      <span class="text-2xl">📦</span>
      <div>
        <p class="font-bold text-red-700 text-lg">Item Indisponível</p>
        <p class="text-red-600 text-sm">Este item já foi doado e não está mais disponível.</p>
      </div>
    </div>
  <% end %>

  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="text-3xl font-bold"><%= @post.title %></h1>
        <% if @post.status == "available" %>
          <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">
            ✅ Disponível
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-700">
            🔒 Doado
          </span>
        <% end %>
      </div>
      <p class="text-gray-600 mt-2">Por <%= link_to @post.user.name, user_path(@post.user), class: "text-blue-600 hover:text-blue-800 hover:underline" %></p>
    </div>
    <div class="flex gap-2">
      <% if @post.user == Current.user %>
        <%= link_to "Editar", edit_post_path(@post), class: "rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white shadow-sm hover:bg-blue-500" %>
        <%= button_to "Deletar", post_path(@post), method: :delete, data: { confirm: "Tem certeza?" }, class: "rounded-lg bg-red-600 px-4 py-2 font-semibold text-white shadow-sm hover:bg-red-500" %>
      <% elsif Current.user && @post.status == "available" %>
        <%= button_to "Tenho Interesse", claim_post_path(@post), method: :post,
            class: "rounded-lg bg-green-600 px-4 py-2 font-semibold text-white shadow-sm hover:bg-green-500",
            data: { confirm: "Enviar mensagem de interesse ao dono do item?" } %>
      <% elsif @post.status == "taken" %>
        <span class="rounded-lg bg-gray-300 px-4 py-2 font-semibold text-gray-600 cursor-not-allowed">Item já doado</span>
      <% end %>
    </div>
  </div>

  <% if @post.images.attached? %>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <% @post.images.each do |image| %>
        <div class="rounded-lg overflow-hidden">
          <%= image_tag image, alt: "preview", class: "h-96 w-full object-cover" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
    <div class="rounded-lg bg-gray-50 p-4">
      <p class="text-sm text-gray-600">Categoria</p>
      <p class="mt-1 font-semibold"><%= @post.category %></p>
    </div>
    <div class="rounded-lg bg-gray-50 p-4">
      <p class="text-sm text-gray-600">Condição</p>
      <p class="mt-1 font-semibold"><%= @post.condition %></p>
    </div>
    <div class="rounded-lg bg-gray-50 p-4">
      <p class="text-sm text-gray-600">Localização</p>
      <p class="mt-1 font-semibold"><%= @post.location %></p>
    </div>
    <div class="rounded-lg bg-gray-50 p-4">
      <p class="text-sm text-gray-600">Data</p>
      <p class="mt-1 font-semibold"><%= l(@post.created_at, format: :short) %></p>
    </div>
  </div>

  <div>
    <h2 class="text-2xl font-bold">Descrição</h2>
    <p class="mt-4 whitespace-pre-wrap text-gray-700"><%= @post.description %></p>
  </div>

  <%# Seção de Avaliação %>
  <% if @post.status == "taken" %>
    <div class="border-t border-gray-200 pt-6 space-y-6">
      <h2 class="text-2xl font-bold">Avaliação</h2>

      <% if @post.review.present? %>
        <%# Exibe a avaliação existente %>
        <div class="rounded-lg border border-yellow-200 bg-yellow-50 p-5 space-y-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="flex gap-0.5">
                <% 5.times do |i| %>
                  <span class="text-xl <%= i < @post.review.rating ? 'text-yellow-400' : 'text-gray-300' %>">★</span>
                <% end %>
              </div>
              <span class="text-sm font-semibold text-gray-700"><%= @post.review.rating %>/5</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="text-xs text-gray-500">por <%= @post.review.user.name %></span>
              <% if authenticated? && (@post.user == Current.user || @post.review.user == Current.user) %>
                <%= button_to "🗑 Remover", post_review_path(@post), method: :delete,
                    data: { confirm: "Tem certeza que deseja remover esta avaliação?" },
                    class: "rounded bg-red-100 px-2 py-1 text-xs font-semibold text-red-600 hover:bg-red-200" %>
              <% end %>
            </div>
          </div>
          <p class="text-gray-700 text-sm whitespace-pre-wrap"><%= @post.review.comment %></p>
        </div>
      <% elsif authenticated? && @post.user != Current.user && !@post.review.present? %>
        <%# Formulário de avaliação para quem ainda não avaliou %>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="text-sm text-gray-600 mb-4">Recebeu este item? Deixe sua avaliação!</p>
          <%= form_with scope: :review, url: post_review_path(@post), method: :post, data: { turbo: false }, class: "space-y-4" do |f| %>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Nota</label>
              <div class="flex gap-2 items-center" id="star-rating">
                <% (1..5).each do |n| %>
                  <button type="button"
                    class="text-3xl text-gray-300 hover:text-yellow-400 transition star-btn"
                    data-value="<%= n %>">★</button>
                <% end %>
                <span class="text-sm text-gray-500 ml-2" id="rating-label">Nenhuma nota selecionada</span>
              </div>
              <input type="hidden" name="review[rating]" id="review_rating_input" value="">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Comentário</label>
              <%= f.text_area :comment, rows: 3, placeholder: "Conte como foi a experiência...",
                  class: "w-full rounded-lg border border-gray-300 px-4 py-2 text-sm focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none resize-none" %>
            </div>
            <%= f.submit "Enviar Avaliação",
                class: "rounded-lg bg-yellow-500 px-5 py-2 text-sm font-semibold text-white hover:bg-yellow-400 cursor-pointer" %>
          <% end %>
        </div>

        <script>
          document.querySelectorAll('.star-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
              var val = parseInt(this.getAttribute('data-value'));
              document.getElementById('review_rating_input').value = val;
              document.getElementById('rating-label').textContent = val + ' de 5';
              document.querySelectorAll('.star-btn').forEach(function(b, i) {
                b.style.color = (i < val) ? '#facc15' : '#d1d5db';
              });
            });
          });
        </script>
      <% else %>
        <p class="text-sm text-gray-400 italic">Nenhuma avaliação ainda.</p>
      <% end %>
    </div>
  <% end %>
</div>

