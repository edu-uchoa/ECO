<div class="space-y-8">
  <% if @post.status == "taken" %>
    <div class="rounded-lg bg-red-50 border border-red-300 px-5 py-4 flex items-center gap-3">
      <span class="text-2xl">📦</span>
      <div>
        <p class="font-bold text-red-700 text-lg">Item Indisponível</p>
        <p class="text-red-600 text-sm">Este item já foi doado e não está mais disponível.</p>
      </div>
    </div>
  <% end %>

  <div class="flex items-center justify-between">
    <div>
      <div class="flex items-center gap-3">
        <h1 class="text-3xl font-bold"><%= @post.title %></h1>
        <% if @post.status == "available" %>
          <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-3 py-1 text-xs font-semibold text-green-700">
            ✅ Disponível
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1 rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-700">
            🔒 Doado
          </span>
        <% end %>
      </div>
      <p class="text-gray-600 mt-2">Por <%= link_to @post.user.name, user_path(@post.user), class: "text-blue-600 hover:text-blue-800 hover:underline" %></p>
    </div>
    <div class="flex gap-2">
      <% if @post.user == Current.user %>
        <%= link_to "Editar", edit_post_path(@post), class: "rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white shadow-sm hover:bg-blue-500" %>
        <%= button_to "Deletar", post_path(@post), method: :delete, data: { confirm: "Tem certeza?" }, class: "rounded-lg bg-red-600 px-4 py-2 font-semibold text-white shadow-sm hover:bg-red-500" %>
      <% elsif Current.user && @post.status == "available" %>
        <%= button_to "Tenho Interesse", claim_post_path(@post), method: :post,
            class: "rounded-lg bg-green-600 px-4 py-2 font-semibold text-white shadow-sm hover:bg-green-500",
            data: { confirm: "Enviar mensagem de interesse ao dono do item?" } %>
      <% elsif @post.status == "taken" %>
        <span class="rounded-lg bg-gray-300 px-4 py-2 font-semibold text-gray-600 cursor-not-allowed">Item já doado</span>
      <% end %>
    </div>
  </div>

  <% if @post.images.attached? %>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
      <% @post.images.each do |image| %>
        <div class="rounded-lg overflow-hidden">
          <%= image_tag image, alt: "preview", class: "h-96 w-full object-cover" %>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
    <div class="rounded-lg bg-gray-50 p-4">
      <p class="text-sm text-gray-600">Categoria</p>
      <p class="mt-1 font-semibold"><%= @post.category %></p>
    </div>
    <div class="rounded-lg bg-gray-50 p-4">
      <p class="text-sm text-gray-600">Condição</p>
      <p class="mt-1 font-semibold"><%= @post.condition %></p>
    </div>
    <div class="rounded-lg bg-gray-50 p-4">
      <p class="text-sm text-gray-600">Localização</p>
      <p class="mt-1 font-semibold"><%= @post.location %></p>
    </div>
    <div class="rounded-lg bg-gray-50 p-4">
      <p class="text-sm text-gray-600">Data</p>
      <p class="mt-1 font-semibold"><%= l(@post.created_at, format: :short) %></p>
    </div>
  </div>

  <div>
    <h2 class="text-2xl font-bold">Descrição</h2>
    <p class="mt-4 whitespace-pre-wrap text-gray-700"><%= @post.description %></p>
  </div>
</div>

