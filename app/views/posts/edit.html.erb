<div class="space-y-8">
  <div>
    <h1 class="text-3xl font-bold">Editar Post</h1>
    <p class="text-gray-600 mt-2">Atualize as informações do seu item</p>
  </div>

  <%= form_with(model: @post, local: true, class: "space-y-6") do |form| %>
    <% if @post.errors.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-4">
        <h2 class="text-red-800 font-semibold"><%= pluralize(@post.errors.count, "erro") %> encontrado:</h2>
        <ul class="mt-2 list-disc list-inside text-red-700">
          <% @post.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :title, "Título do Item", class: "block text-sm font-semibold text-gray-700" %>
      <%= form.text_field :title, class: "mt-2 block w-full rounded-lg border-gray-300 px-4 py-2 border shadow-sm" %>
    </div>

    <div>
      <%= form.label :description, "Descrição", class: "block text-sm font-semibold text-gray-700" %>
      <%= form.text_area :description, rows: 5, class: "mt-2 block w-full rounded-lg border-gray-300 px-4 py-2 border shadow-sm" %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <div>
        <%= form.label :category, "Categoria", class: "block text-sm font-semibold text-gray-700" %>
        <%= form.select :category, Post::CATEGORIES, class: "mt-2 block w-full rounded-lg border-gray-300 px-4 py-2 border shadow-sm" %>
      </div>

      <div>
        <%= form.label :condition, "Condição de Uso", class: "block text-sm font-semibold text-gray-700" %>
        <%= form.select :condition, Post::CONDITIONS, class: "mt-2 block w-full rounded-lg border-gray-300 px-4 py-2 border shadow-sm" %>
      </div>
    </div>

    <div>
      <%= form.label :location, "Localização", class: "block text-sm font-semibold text-gray-700" %>
      <%= form.text_field :location, class: "mt-2 block w-full rounded-lg border-gray-300 px-4 py-2 border shadow-sm" %>
    </div>

    <div>
      <label class="block text-sm font-semibold text-gray-700">Imagens Atuais</label>
      <div class="mt-4 grid grid-cols-2 gap-4 md:grid-cols-3">
        <% @post.images.each do |image| %>
          <div class="relative">
            <%= image_tag image, alt: "preview", class: "h-32 w-full rounded-lg object-cover" %>
          </div>
        <% end %>
      </div>
    </div>

    <div>
      <%= form.label :images, "Adicionar Novas Imagens", class: "block text-sm font-semibold text-gray-700" %>
      <div class="mt-2 flex justify-center rounded-lg border-2 border-dashed border-gray-300 px-6 py-10">
        <div class="text-center">
          <%= form.file_field :images, multiple: true, accept: "image/*", class: "block w-full" %>
          <p class="mt-2 text-sm text-gray-600">PNG, JPG ou WEBP até 5MB</p>
        </div>
      </div>
    </div>

    <div class="flex gap-4">
      <%= form.submit "Atualizar Post", class: "rounded-lg bg-blue-600 px-6 py-2 font-semibold text-white shadow-sm hover:bg-blue-500 active:bg-blue-700" %>
      <%= link_to "Cancelar", @post, class: "rounded-lg bg-gray-300 px-6 py-2 font-semibold text-gray-900 shadow-sm hover:bg-gray-400" %>
    </div>
  <% end %>
</div>
