<div class="space-y-12">

    <h1 class="text-3xl font-bold">
        Bem-vindo, <%= Current.user.name %>! 👋
    </h1>

    <div class="flex gap-4">
        <%= link_to "Criar Novo Post", new_post_path, class: "rounded-lg bg-green-600 px-4 py-2 text-center font-semibold text-white shadow-sm hover:bg-green-500 active:bg-green-700" %>
    </div>

    <% if Current.user.posts.any? %>
        <div class="space-y-4">            <h2 class="text-2xl font-bold">Meus Posts</h2>
            <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                <% Current.user.posts.recent.each do |post| %>
                    <div class="overflow-hidden rounded-lg border border-gray-200 shadow-sm hover:shadow-md transition-shadow">
                        <% if post.images.attached? %>
                            <div class="h-40 overflow-hidden bg-gray-100">
                                <%= image_tag post.images.first, alt: post.title, class: "h-full w-full object-cover" %>
                            </div>
                        <% else %>
                            <div class="h-40 bg-gray-200 flex items-center justify-center">
                                <span class="text-gray-400">Sem imagem</span>
                            </div>
                        <% end %>
                        
                        <div class="p-4 space-y-2">
                            <h3 class="font-bold text-gray-900"><%= post.title %></h3>
                            <p class="line-clamp-2 text-sm text-gray-700"><%= post.description %></p>
                            
                            <div class="flex flex-wrap gap-1">
                                <span class="inline-block rounded-full bg-blue-100 px-2 py-1 text-xs text-blue-700">
                                    <%= post.category %>
                                </span>
                                <span class="inline-block rounded-full bg-green-100 px-2 py-1 text-xs text-green-700">
                                    <%= post.condition %>
                                </span>
                            </div>
                            
                            <div class="text-xs text-gray-600">📍 <%= post.location %></div>
                            
                            <div class="flex gap-2">
                                <%= link_to "Ver", post_path(post), class: "flex-1 rounded bg-blue-600 px-2 py-1 text-center text-xs font-semibold text-white hover:bg-blue-500" %>
                                <%= link_to "Editar", edit_post_path(post), class: "flex-1 rounded bg-yellow-600 px-2 py-1 text-center text-xs font-semibold text-white hover:bg-yellow-500" %>
                                <%= button_to "Deletar", post_path(post), method: :delete, data: { confirm: "Tem certeza?" }, class: "flex-1 rounded bg-red-600 px-2 py-1 text-center text-xs font-semibold text-white hover:bg-red-500" %>
                            </div>
                        </div>
                    </div>
                <% end %>
            </div>
        </div>
    <% end %>

    <div class="space-y-4">
        <h2 class="text-2xl font-bold">Itens Disponíveis para Doação</h2>
        <% all_posts = Post.recent.where.not(user_id: Current.user.id) %>
        <% if all_posts.any? %>
            <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                <% all_posts.limit(6).each do |post| %>
                    <div class="overflow-hidden rounded-lg border border-gray-200 shadow-sm hover:shadow-md transition-shadow">
                        <% if post.images.attached? %>
                            <div class="h-40 overflow-hidden bg-gray-100">
                                <%= image_tag post.images.first, alt: post.title, class: "h-full w-full object-cover" %>
                            </div>
                        <% else %>
                            <div class="h-40 bg-gray-200 flex items-center justify-center">
                                <span class="text-gray-400">Sem imagem</span>
                            </div>
                        <% end %>
                        
                        <div class="p-4 space-y-2">
                            <h3 class="font-bold text-gray-900"><%= post.title %></h3>
                            <p class="text-xs text-gray-600">Por <%= link_to post.user.name, user_path(post.user), class: "text-blue-600 hover:text-blue-800 hover:underline" %></p>
                            <p class="line-clamp-2 text-sm text-gray-700"><%= post.description %></p>
                            
                            <div class="flex flex-wrap gap-1">
                                <span class="inline-block rounded-full bg-blue-100 px-2 py-1 text-xs text-blue-700">
                                    <%= post.category %>
                                </span>
                                <span class="inline-block rounded-full bg-green-100 px-2 py-1 text-xs text-green-700">
                                    <%= post.condition %>
                                </span>
                            </div>
                            
                            <div class="text-xs text-gray-600">📍 <%= post.location %></div>
                            
                            <%= link_to "Ver Detalhes", post_path(post), class: "block rounded bg-blue-600 px-3 py-2 text-center text-xs font-semibold text-white hover:bg-blue-500" %>
                        </div>
                    </div>
                <% end %>
            </div>
            <%= link_to "Ver Todos os Itens", posts_path, class: "inline-block rounded-lg bg-blue-600 px-4 py-2 font-semibold text-white shadow-sm hover:bg-blue-500" %>
        <% else %>
            <div class="rounded-lg border-2 border-dashed border-gray-300 p-12 text-center">
                <p class="text-gray-600">Nenhum item disponível no momento</p>
            </div>
        <% end %>
    </div>

</div>