<div class="space-y-12">

    <h1 class="text-3xl font-bold">
        Bem Vindo, <%= Current.user.name %> !
    </h1>

    <div class="flex gap-4">
        <%= link_to "Meu Perfil", profile_path, class: "rounded-lg bg-blue-600 px-3 py-2 text-center font-semibold text-white shadow-sm hover:bg-blue-500 active:bg-blue-700" %>
        <%= button_to "Logout", session_path, method: :delete, class: "rounded-lg bg-red-600 px-3 py-2 font-semibold text-white shadow-sm hover:bg-red-500 active:bg-red-700" %>
    </div>

</div>