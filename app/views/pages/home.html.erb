<div class="w-full">
    <div class="py-8">
        <div class="max-w-6xl mx-auto px-6 py-12 text-center">
            <h2 class="text-4xl font-extrabold mb-4 text-gray-900">Bem-vindo ao ProjetoFinal</h2>
            <p class="text-lg text-gray-600 mb-8">Explore itens disponíveis para doação. Cadastre-se para compartilhar seus itens.</p>

            <% if !authenticated? %>
              <div class="flex justify-center gap-4">
                  <%= link_to "Começar", new_user_path, class: "px-6 py-3 rounded-md bg-blue-600 text-white hover:bg-blue-500 font-semibold" %>
                  <%= link_to "Saiba mais", '#posts-section', class: "px-6 py-3 rounded-md border border-gray-200 text-gray-700 hover:bg-gray-100 font-semibold" %>
              </div>
            <% end %>
        </div>

        <!-- Posts Section -->
        <div class="max-w-6xl mx-auto px-6 py-12" id="posts-section">
            <div>
                <h2 class="text-3xl font-bold mb-6">Itens para Doação</h2>
            </div>

            <% @posts = Post.recent %>
            <% if @posts.any? %>
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                    <% @posts.each do |post| %>
                        <div class="overflow-hidden rounded-lg border border-gray-200 shadow-sm hover:shadow-md transition-shadow">
                            <% if post.images.attached? %>
                                <div class="h-48 overflow-hidden bg-gray-100">
                                    <%= image_tag post.images.first, alt: post.title, class: "h-full w-full object-cover" %>
                                </div>
                            <% else %>
                                <div class="h-48 bg-gray-200 flex items-center justify-center">
                                    <span class="text-gray-400">Sem imagem</span>
                                </div>
                            <% end %>

                            <div class="p-4 space-y-3">
                                <div>
                                    <h3 class="font-bold text-lg text-gray-900"><%= post.title %></h3>
                                    <%= link_to post.user.name, user_path(post.user), class: "text-sm text-blue-600 hover:text-blue-800 hover:underline" %>
                                </div>

                                <p class="line-clamp-2 text-sm text-gray-700"><%= post.description %></p>

                                <div class="flex flex-wrap gap-2">
                                    <span class="inline-block rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-700">
                                        <%= post.category %>
                                    </span>
                                    <span class="inline-block rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">
                                        <%= post.condition %>
                                    </span>
                                </div>

                                <div class="text-sm text-gray-600">
                                    📍 <%= post.location %>
                                </div>

                                <%= link_to "Ver Detalhes", post_path(post), class: "inline-block rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 w-full text-center" %>
                            </div>
                        </div>
                    <% end %>
                </div>
            <% else %>
                <div class="rounded-lg border-2 border-dashed border-gray-300 p-12 text-center">
                    <p class="text-gray-600">Nenhum item encontrado</p>
                </div>
            <% end %>
        </div>
    </div>
</div>