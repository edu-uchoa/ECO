<div class="fixed inset-0 bg-gray-50">
    <!-- Full-viewport gray background; inner wrapper provides a 5% padding margin -->
    <div class="h-full overflow-auto" style="padding:5%;">
        <header class="max-w-6xl mx-auto px-6 py-6 flex items-center justify-between">
            <h1 class="text-2xl font-bold text-gray-800">ProjetoFinal</h1>

            <div class="flex items-center gap-3">
                <%= link_to "Login", new_session_path, class: "px-4 py-2 rounded-md bg-blue-600 text-white hover:bg-blue-500" %>
                <%= link_to "Sign up", new_user_path, class: "px-4 py-2 rounded-md border border-blue-600 text-blue-600 hover:bg-blue-50" %>
            </div>
        </header>

        <main class="max-w-6xl mx-auto px-6 py-20">
            <div class="text-center mb-16">
                <h2 class="text-4xl font-extrabold mb-4 text-gray-900">Welcome to the Home Page</h2>
                <p class="text-lg text-gray-600 mb-8">Explore items available for donation. Sign up to get started and share your items.</p>

                <div class="flex justify-center gap-4">
                    <%= link_to "Get started", new_user_path, class: "px-6 py-3 rounded-md bg-blue-600 text-white hover:bg-blue-500" %>
                    <%= link_to "Learn more", '#', class: "px-6 py-3 rounded-md border border-gray-200 text-gray-700 hover:bg-gray-100" %>
                </div>
            </div>

            <!-- Posts Section -->
            <div class="space-y-8">
                <div>
                    <h2 class="text-3xl font-bold mb-6">Itens para Doação</h2>
                </div>

                <% @posts = Post.recent %>
                <% if @posts.any? %>
                    <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
                        <% @posts.each do |post| %>
                            <div class="overflow-hidden rounded-lg border border-gray-200 shadow-sm hover:shadow-md transition-shadow">
                                <% if post.images.attached? %>
                                    <div class="h-48 overflow-hidden bg-gray-100">
                                        <%= image_tag post.images.first, alt: post.title, class: "h-full w-full object-cover" %>
                                    </div>
                                <% else %>
                                    <div class="h-48 bg-gray-200 flex items-center justify-center">
                                        <span class="text-gray-400">Sem imagem</span>
                                    </div>
                                <% end %>

                                <div class="p-4 space-y-3">
                                    <div>
                                        <h3 class="font-bold text-lg text-gray-900"><%= post.title %></h3>
                                        <p class="text-sm text-gray-600"><%= post.user.name %></p>
                                    </div>

                                    <p class="line-clamp-2 text-sm text-gray-700"><%= post.description %></p>

                                    <div class="flex flex-wrap gap-2">
                                        <span class="inline-block rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-700">
                                            <%= post.category %>
                                        </span>
                                        <span class="inline-block rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">
                                            <%= post.condition %>
                                        </span>
                                    </div>

                                    <div class="text-sm text-gray-600">
                                        📍 <%= post.location %>
                                    </div>

                                    <%= link_to "Ver Detalhes", post_path(post), class: "inline-block rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 w-full text-center" %>
                                </div>
                            </div>
                        <% end %>
                    </div>
                <% else %>
                    <div class="rounded-lg border-2 border-dashed border-gray-300 p-12 text-center">
                        <p class="text-gray-600">Nenhum item encontrado</p>
                    </div>
                <% end %>
            </div>
        </main>
    </div>
</div>