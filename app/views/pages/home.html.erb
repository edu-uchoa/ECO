<div class="fixed inset-0 bg-gray-50">
    <!-- Full-viewport gray background; inner wrapper provides a 5% padding margin -->
    <div class="h-full overflow-auto" style="padding:5%;">
        <header class="max-w-6xl mx-auto px-6 py-6 flex items-center justify-between">
            <h1 class="text-2xl font-bold text-gray-800">ProjetoFinal</h1>

            <div class="flex items-center gap-3">
                <%= link_to "Login", new_session_path, class: "px-4 py-2 rounded-md bg-blue-600 text-white hover:bg-blue-500" %>
                <%= link_to "Sign up", new_user_path, class: "px-4 py-2 rounded-md border border-blue-600 text-blue-600 hover:bg-blue-50" %>
            </div>
        </header>

        <main class="max-w-3xl mx-auto px-6 py-20 text-center">
            <h2 class="text-4xl font-extrabold mb-4 text-gray-900">Welcome to the Home Page</h2>
            <p class="text-lg text-gray-600 mb-8">A short description of your app goes here. Sign up to get started and explore the dashboard.</p>

            <div class="flex justify-center gap-4">
                <%= link_to "Get started", new_user_path, class: "px-6 py-3 rounded-md bg-blue-600 text-white hover:bg-blue-500" %>
                <%= link_to "Learn more", '#', class: "px-6 py-3 rounded-md border border-gray-200 text-gray-700 hover:bg-gray-100" %>
            </div>
        </main>
    </div>
</div>