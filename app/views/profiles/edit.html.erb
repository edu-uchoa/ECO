<div class="space-y-12">
  <div class="mx-auto max-w-sm">
    <h1 class="text-2xl font-bold">Editar Perfil</h1>
    
    <%= form_with model: @user, url: profile_path, method: :patch, local: true, class: "space-y-6" do |form| %>
      
      <% if @user.errors.any? %>
        <div id="error_explanation" class="rounded-lg bg-red-50 p-4">
          <h2 class="font-semibold text-red-800">
            <%= pluralize(@user.errors.count, "erro") %> ao atualizar perfil:
          </h2>
          <ul class="mt-2 list-inside space-y-1 text-sm text-red-700">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :name, "Nome" %>
        <%= form.text_field :name, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :email_address, "Email" %>
        <%= form.email_field :email_address, class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500" %>
      </div>

      <div class="rounded-lg bg-blue-50 p-4">
        <h3 class="font-semibold text-blue-900">Alteração de Senha</h3>
        <p class="mt-1 text-sm text-blue-700">Deixe os campos vazios se não quiser alterar a senha</p>
      </div>

      <div>
        <%= form.label :password, "Nova Senha" %>
        <%= form.password_field :password, autocomplete: "new-password", placeholder: "Mínimo 6 caracteres", class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Confirmar Senha" %>
        <%= form.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirme a nova senha", class: "mt-2 block w-full rounded-lg border border-gray-300 px-3 py-2 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-blue-500" %>
      </div>

      <div class="rounded-lg bg-amber-50 p-4">
        <p class="text-sm text-amber-800">
          <strong>⚠️ Aviso:</strong> Se alterar a senha, você será desconectado automaticamente e precisará fazer login novamente com a nova senha.
        </p>
      </div>

      <div class="flex gap-4">
        <%= form.submit "Salvar Alterações", class: "rounded-lg bg-blue-600 px-3 py-2 font-semibold text-white shadow-sm hover:bg-blue-500 active:bg-blue-700" %>
        <%= link_to "Cancelar", profile_path, class: "rounded-lg bg-gray-200 px-3 py-2 text-center font-semibold text-gray-900 shadow-sm hover:bg-gray-100 active:bg-gray-300" %>
      </div>
    <% end %>

    <hr class="my-8">

    <div class="space-y-4">
      <h2 class="text-lg font-bold text-red-600">Zona de Perigo</h2>
      <p class="text-sm text-gray-600">A exclusão da conta é permanente e não pode ser desfeita.</p>
      
      <%= button_to "Excluir Minha Conta", profile_path, method: :delete,
          form: { data: { turbo_confirm: "Tem certeza que deseja excluir sua conta? Esta ação é irreversível!" } },
          class: "rounded-lg bg-red-600 px-3 py-2 font-semibold text-white shadow-sm hover:bg-red-500 active:bg-red-700" %>
    </div>
  </div>
</div>

<div class="mb-4">
  <%= js_back_button "Back", class: "px-3 py-2 rounded bg-gray-100 text-sm" %>
</div>