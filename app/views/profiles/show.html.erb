<div class="space-y-12">
  <div class="mx-auto max-w-sm">
    <h1 class="text-2xl font-bold">Meu Perfil</h1>
    
    <div class="mt-8 space-y-6">
      <div>
        <label class="block text-sm font-medium text-gray-700">Nome</label>
        <div class="mt-1 text-base text-gray-900"><%= @user.name %></div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700">Email</label>
        <div class="mt-1 text-base text-gray-900"><%= @user.email_address %></div>
      </div>
    </div>

    <div class="mt-8 flex gap-4">
      <%= link_to "Editar Perfil", edit_profile_path, class: "rounded-lg bg-blue-600 px-3 py-2 text-center font-semibold text-white shadow-sm hover:bg-blue-500 active:bg-blue-700" %>
      <%= link_to "Voltar ao Dashboard", dashboard_path, class: "rounded-lg bg-gray-200 px-3 py-2 text-center font-semibold text-gray-900 shadow-sm hover:bg-gray-100 active:bg-gray-300" %>
    </div>
  </div>

  <%# Itens disponíveis %>
  <div class="space-y-4">
    <h2 class="text-2xl font-bold flex items-center gap-2">
      ✅ Meus Itens Disponíveis
      <span class="rounded-full bg-green-100 px-3 py-1 text-sm font-semibold text-green-700"><%= @available_posts.count %></span>
    </h2>
    <% if @available_posts.any? %>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% @available_posts.each do |post| %>
          <div class="overflow-hidden rounded-lg border border-green-200 shadow-sm hover:shadow-md transition-shadow">
            <% if post.images.attached? %>
              <div class="h-40 overflow-hidden bg-gray-100">
                <%= image_tag post.images.first, alt: post.title, class: "h-full w-full object-cover" %>
              </div>
            <% else %>
              <div class="h-40 bg-gray-200 flex items-center justify-center">
                <span class="text-gray-400">Sem imagem</span>
              </div>
            <% end %>
            <div class="p-4 space-y-2">
              <h3 class="font-bold text-gray-900"><%= post.title %></h3>
              <p class="line-clamp-2 text-sm text-gray-700"><%= post.description %></p>
              <div class="flex flex-wrap gap-1">
                <span class="inline-block rounded-full bg-blue-100 px-2 py-1 text-xs text-blue-700"><%= post.category %></span>
                <span class="inline-block rounded-full bg-green-100 px-2 py-1 text-xs text-green-700"><%= post.condition %></span>
              </div>
              <div class="text-xs text-gray-600">📍 <%= post.location %></div>
              <div class="flex gap-2 pt-1">
                <%= link_to "Ver", post_path(post), class: "flex-1 rounded bg-blue-600 px-2 py-1 text-center text-xs font-semibold text-white hover:bg-blue-500" %>
                <%= link_to "Editar", edit_post_path(post), class: "flex-1 rounded bg-yellow-500 px-2 py-1 text-center text-xs font-semibold text-white hover:bg-yellow-400" %>
                <%= button_to "Deletar", post_path(post), method: :delete, data: { confirm: "Tem certeza?" }, class: "flex-1 rounded bg-red-600 px-2 py-1 text-center text-xs font-semibold text-white hover:bg-red-500" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="rounded-lg border-2 border-dashed border-green-200 p-8 text-center">
        <p class="text-gray-500">Você não tem itens disponíveis no momento.</p>
        <%= link_to "Adicionar Item", new_post_path, class: "mt-3 inline-block rounded-lg bg-green-600 px-4 py-2 text-sm font-semibold text-white hover:bg-green-500" %>
      </div>
    <% end %>
  </div>

  <%# Itens já doados %>
  <% if @taken_posts.any? %>
    <div class="space-y-4">
      <h2 class="text-2xl font-bold flex items-center gap-2">
        🔒 Itens Já Doados
        <span class="rounded-full bg-red-100 px-3 py-1 text-sm font-semibold text-red-700"><%= @taken_posts.count %></span>
      </h2>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        <% @taken_posts.each do |post| %>
          <div class="overflow-hidden rounded-lg border border-red-200 shadow-sm opacity-75">
            <% if post.images.attached? %>
              <div class="h-40 overflow-hidden bg-gray-100">
                <%= image_tag post.images.first, alt: post.title, class: "h-full w-full object-cover grayscale" %>
              </div>
            <% else %>
              <div class="h-40 bg-gray-200 flex items-center justify-center">
                <span class="text-gray-400">Sem imagem</span>
              </div>
            <% end %>
            <div class="p-4 space-y-2">
              <div class="flex items-center gap-2">
                <h3 class="font-bold text-gray-500"><%= post.title %></h3>
                <span class="rounded-full bg-red-100 px-2 py-0.5 text-xs font-semibold text-red-600">Doado</span>
              </div>
              <p class="line-clamp-2 text-sm text-gray-400"><%= post.description %></p>
              <div class="flex flex-wrap gap-1">
                <span class="inline-block rounded-full bg-gray-100 px-2 py-1 text-xs text-gray-500"><%= post.category %></span>
                <span class="inline-block rounded-full bg-gray-100 px-2 py-1 text-xs text-gray-500"><%= post.condition %></span>
              </div>
              <div class="text-xs text-gray-400">📍 <%= post.location %></div>

              <%# Avaliação recebida %>
              <% if post.review.present? %>
                <div class="rounded-lg bg-yellow-50 border border-yellow-200 px-3 py-2 space-y-1">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-1">
                      <% 5.times do |i| %>
                        <span class="text-sm <%= i < post.review.rating ? 'text-yellow-400' : 'text-gray-300' %>">★</span>
                      <% end %>
                      <span class="text-xs text-gray-500 ml-1">por <%= post.review.user.name %></span>
                    </div>
                    <%= button_to "🗑", post_review_path(post), method: :delete,
                        data: { confirm: "Remover esta avaliação?" },
                        class: "rounded bg-red-100 px-1.5 py-0.5 text-xs text-red-600 hover:bg-red-200" %>
                  </div>
                  <p class="text-xs text-gray-600 line-clamp-2"><%= post.review.comment %></p>
                </div>
              <% else %>
                <p class="text-xs text-gray-400 italic">Sem avaliação ainda.</p>
              <% end %>

              <div class="flex gap-2 pt-1">
                <%= link_to "Ver", post_path(post), class: "flex-1 rounded bg-gray-400 px-2 py-1 text-center text-xs font-semibold text-white" %>
                <%= button_to "Deletar", post_path(post), method: :delete, data: { confirm: "Tem certeza?" }, class: "flex-1 rounded bg-red-400 px-2 py-1 text-center text-xs font-semibold text-white hover:bg-red-500" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
